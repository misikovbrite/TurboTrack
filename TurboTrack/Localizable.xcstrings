    "My hands used to shake for days before a flight. Now I just check the app and breathe.": {
      "extractionState": "stale",
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Mine hænder rystede i dagevis før en flyvning. Nu tjekker jeg bare appen og trækker vejret."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Meine Hände zitterten tagelang vor einem Flug. Jetzt prüfe ich einfach die App und atme."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mis manos temblaban días antes de un vuelo. Ahora solo reviso la app y respiro."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mes mains tremblaient des jours avant un vol. Maintenant je vérifie l'app et je respire."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Hendene mine pleide å skjelve dagene før en flyreise. Nå sjekker jeg bare appen og puster."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Minhas mãos tremiam dias antes de um voo. Agora eu apenas verifico o app e respiro."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Раньше у меня тряслись руки за дни до полёта. Теперь я просто проверяю приложение и дышу."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Mina händer brukade skaka dagarna före en flygning. Nu kollar jag bara appen och andas."
          }
        }
      }
    },
    "My heart pounds and palms sweat": {
      "extractionState": "stale",
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Mit hjerte hamrer og hænderne sveder"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Mein Herz klopft und die Hände schwitzen"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mi corazón late fuerte y me sudan las manos"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mon cœur bat fort et mes mains transpirent"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Hjertet banker og hendene svetter"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Meu coração dispara e as mãos suam"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сердце колотится и ладони потеют"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Mitt hjärta bultar och händerna svettas"
          }
        }
      }
    },
