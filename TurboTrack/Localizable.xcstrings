    "I recommend this to nervous passengers. Knowledge really does replace fear.": {
      "extractionState": "stale",
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Jeg anbefaler dette til nervøse passagerer. Viden erstatter virkelig frygt."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ich empfehle dies nervösen Passagieren. Wissen ersetzt wirklich die Angst."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Lo recomiendo a pasajeros nerviosos. El conocimiento realmente reemplaza el miedo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je recommande ceci aux passagers nerveux. Le savoir remplace vraiment la peur."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Jeg anbefaler dette til nervøse passasjerer. Kunnskap erstatter virkelig frykt."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Recomendo a passageiros nervosos. O conhecimento realmente substitui o medo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Рекомендую нервным пассажирам. Знание действительно заменяет страх."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Jag rekommenderar detta till nervösa passagerare. Kunskap ersätter verkligen rädsla."
          }
        }
      }
    },
