        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Просто введи номер рейса —\nmi найдём маршрут и прогноз автоматически"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Ange bara ditt flygnummer —\nvi hittar rutten och prognosen automatiskt"
          }
        }
      }
    },
