    "Light conditions — any seat will be comfortable": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Lette forhold — ethvert sæde er behageligt"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Leichte Bedingungen — jeder Sitz ist bequem"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Condiciones suaves — cualquier asiento es cómodo"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Conditions légères — tout siège sera confortable"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Lette forhold — ethvert sete er behagelig"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Condições leves — qualquer assento é confortável"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Лёгкие условия — любое место будет комфортным"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Lätta förhållanden — vilket säte som helst är bekvämt"
          }
        }
      }
    },
    "Sit over the wing (middle rows) — it's the plane's center of gravity and feels the least motion": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Sid over vingen (midterrækker) — det er flyets tyngdepunkt og føles mindst bevægelse"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sitz über dem Flügel (mittlere Reihen) — dort ist der Schwerpunkt und es schaukelt am wenigsten"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Siéntate sobre el ala (filas centrales) — es el centro de gravedad y se siente menos movimiento"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Assieds-toi au-dessus de l'aile (rangées centrales) — c'est le centre de gravité, le moins de mouvement"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Sitt over vingen (midtre rader) — det er flyets tyngdepunkt og kjennes minst bevegelse"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Sente-se sobre a asa (fileiras centrais) — é o centro de gravidade e sente menos movimento"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Садитесь над крылом (средние ряды) — это центр тяжести самолёта, наименьшая болтанка"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Sitt över vingen (mellersta rader) — det är planets tyngdpunkt och känns minst rörelse"
          }
        }
      }
    },
    "Over the wing strongly recommended — rear seats can feel up to 2× more turbulence than the middle": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Over vingen anbefales kraftigt — bagsæder kan føle op til 2× mere turbulens end midten"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Über dem Flügel wird dringend empfohlen — hintere Sitze können bis zu 2× mehr Turbulenz spüren"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sobre el ala muy recomendado — los asientos traseros pueden sentir hasta 2× más turbulencias"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Au-dessus de l'aile fortement recommandé — les sièges arrière ressentent jusqu'à 2× plus de turbulences"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Over vingen anbefales sterkt — bakseter kan kjenne opptil 2× mer turbulens enn midten"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Sobre a asa altamente recomendado — assentos traseiros podem sentir até 2× mais turbulência"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Над крылом настоятельно рекомендуется — хвостовые места ощущают до 2× больше болтанки"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Över vingen rekommenderas starkt — baksäten kan känna upp till 2× mer turbulens än mitten"
          }
        }
      }
    },
