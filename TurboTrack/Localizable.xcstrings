    "From a gentle ripple to a bumpy road —\nwe explain each level in plain words": {
      "extractionState": "stale",
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Fra en let krusning til en ujævn vej —\nvi forklarer hvert niveau med enkle ord"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Von einem leichten Rippeln bis zur Holperstrecke —\nwir erklären jede Stufe verständlich"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Desde una leve ondulación hasta un camino con baches —\nexplicamos cada nivel en palabras simples"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "D'une légère ondulation à une route bosselée —\nnous expliquons chaque niveau simplement"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Fra en lett krusning til en humpete vei —\nvi forklarer hvert nivå med enkle ord"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "De uma leve ondulação a uma estrada esburacada —\nexplicamos cada nível em palavras simples"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "От лёгкой ряби до тряски —\nмы объясняем каждый уровень простыми словами"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Från en lätt krusning till en guppig väg —\nvi förklarar varje nivå i enkla ord"
          }
        }
      }
    },
