    "We know flying can be stressful.\nLet's take the uncertainty away.": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Vi ved, at det kan være stressende at flyve.\nLad os fjerne usikkerheden."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wir wissen, dass Fliegen stressig sein kann.\nLass uns die Ungewissheit beseitigen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sabemos que volar puede ser estresante.\nElimina la incertidumbre."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nous savons que voler peut être stressant.\nÉliminons l’incertitude ensemble."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Vi vet at flyging kan være stressende.\nLa oss fjerne usikkerheten."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Sabemos que voar pode ser estressante.\nVamos eliminar a incerteza."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Мы знаем, что перелёты могут быть стрессовыми.\nДавай избавимся от неизвестности."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Vi vet att flygning kan vara stressande.\nLåt oss ta bort osäkerheten."
          }
        }
      }
    },
