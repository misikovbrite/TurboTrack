    "We recommend the best seat based on your route's turbulence forecast": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Vi anbefaler det bedste sæde baseret på din rutes turbulensforecast"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wir empfehlen den besten Sitz basierend auf der Turbulensprognose deiner Route"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Recomendamos el mejor asiento según el pronóstico de turbulencia de tu ruta"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nous recommandons le meilleur siège selon les prévisions de turbulences de votre route"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Vi anbefaler det beste setet basert på turbulensvarsel for ruten din"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Recomendamos o melhor assento com base na previsão de turbulência da sua rota"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Мы рекомендуем лучшее место на основе прогноза турбулентности вашего маршрута"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Vi rekommenderar det bästa sätet baserat på turbulenspasset för din rutt"
          }
        }
      }
    },
    "Middle rows over the wing feel up to 2× less turbulence than the rear": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Midterrækker over vingen føler op til 2× mindre turbulens end bagerst"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Mittlere Reihen über dem Flügel spüren bis zu 2× weniger Turbulenz als hinten"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las filas centrales sobre el ala sienten hasta 2× menos turbulencia que la parte trasera"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les rangées centrales au-dessus de l'aile ressentent jusqu'à 2× moins de turbulences que l'arrière"
