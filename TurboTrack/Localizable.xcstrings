    "This takes about a minute.\nYou can minimize the app —\nwe'll have your report ready\nwhen you come back.": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Dette tager cirka et minut.\nDu kan minimere appen —\nvi har din rapport klar,\nnår du vender tilbage."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das dauert etwa eine Minute.\nDu kannst die App minimieren —\ndein Bericht ist fertig,\nwenn du zurückkommst."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto toma alrededor de un minuto.\nPuedes minimizar la app —\ntu informe estará listo\ncuando vuelvas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela prend environ une minute.\nTu peux réduire l’app —\nton rapport sera prêt\nquand tu reviendras."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Dette tar omtrent ett minutt.\nDu kan minimere appen —\nvi har rapporten din klar\nnår du kommer tilbake."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Isso leva cerca de um minuto.\nVocê pode minimizar o app —\nteremos seu relatório pronto\nquando você voltar."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Это займёт около минуты.\nМожно свернуть приложение —\nотчёт будет готов,\nкогда ты вернёшься."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Det tar ungefär en minut.\nDu kan minimera appen —\ndin rapport är klar\nnär du kommer tillbaka."
          }
        }
      }
    },
