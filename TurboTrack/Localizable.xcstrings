    "I used to dread every flight. Now I check the forecast and know exactly what to expect.": {
      "extractionState": "stale",
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Jeg plejede at frygte hver flyvning. Nu tjekker jeg prognosen og ved præcis hvad jeg kan forvente."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Früher hatte ich vor jedem Flug Angst. Jetzt prüfe ich die Vorhersage und weiß genau, was mich erwartet."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Solía temer cada vuelo. Ahora reviso el pronóstico y sé exactamente qué esperar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Avant, je redoutais chaque vol. Maintenant je vérifie la prévision et sais exactement à quoi m'attendre."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Jeg pleide å frykte hver flyreise. Nå sjekker jeg prognosen og vet nøyaktig hva jeg kan forvente."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Eu costumava temer cada voo. Agora verifico a previsão e sei exatamente o que esperar."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Раньше я боялась каждого полёта. Теперь проверяю прогноз и точно знаю, чего ожидать."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Jag brukade frukta varje flygning. Nu kollar jag prognosen och vet exakt vad jag kan förvänta mig."
          }
        }
      }
    },
